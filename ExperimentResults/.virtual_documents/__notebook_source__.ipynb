PARQUET_PATH  = "/kaggle/input/datasets/sauravchaudhary19/openfaketestfile1/test-00000-of-00007.parquet"    # path to your downloaded parquet file
BATCH_SIZE    = 32                          # reduce to 16 if you run out of GPU memory
NUM_EPOCHS    = 10                         # max epochs (early stopping will kick in sooner)
LR            = 2e-4                        # learning rate
WEIGHT_DECAY  = 1e-4                        # L2 regularisation
PATIENCE      = 3                           # early stopping: epochs without improvement
NUM_WORKERS   = 4                           # parallel data loading (set 0 on Windows)
CHECKPOINT_DIR = "checkpoints"
RESULTS_DIR    = "results"

